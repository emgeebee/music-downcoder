{
  "ffmpeg": "/usr/bin/ffmpeg",
  "rate": "0",
  "numOfCores": 4,
  "commandsFolder": "/data/cmd",
  "queueFolder": "/data/queueInProgress",
  "metaFile": "/data/config/meta.json",
  "workDir": "/data",
  "autoConfirm": true,
  "startFolders": [
    {
      "name": "Downloads",
      "path": "/data/music"
    },
    {
      "name": "Itunes",
      "path": "/data/itunes"
    }
  ],
  "encoders": [
    {
      "id": "alac",
      "label": "ALAC",
      "description": "Copies the files directly (hopefully it's ALAC)",
      "default": true,
      "out": "/data/cds-alac",
      "format": "cp",
      "getImages": false
    },
    {
      "id": "main",
      "label": "mp3",
      "default": true,
      "out": "/data/cds-mp3",
      "format": "mp3"
    }
  ]
}

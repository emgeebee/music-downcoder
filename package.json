{
  "name": "@emgeebee/music_downcoder",
  "version": "1.2.0",
  "description": "Scan music libraries and generate ffmpeg conversion scripts with a CLI or web UI",
  "type": "module",
  "bin": {
    "music_downcoder": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "batch.sh"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/web && cp src/web/index.html dist/web/index.html && npm run type-check",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "serve": "tsx src/index.ts serve -c docker/conf.local.json -H 127.0.0.1 -p 3798",
    "list": "find ./cmd/**/*.sh -type f 2>/dev/null | sort -nr",
    "convert": "./batch.sh",
    "clean-empty": "tsx src/cleanEmptyFolders.ts -c docker/conf.local.json",
    "sync-meta": "tsx src/syncMetaFromLocal.ts -c docker/conf.local.json",
    "repair-meta-years": "tsx src/repairMetaYears.ts -c docker/conf.local.json",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.6.0",
    "fs-extra": "*",
    "minimist": "^1.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emgeebee/music-downcoder.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
